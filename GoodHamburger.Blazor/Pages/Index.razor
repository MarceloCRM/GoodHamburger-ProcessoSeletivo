@page "/"
@using GoodHamburger.Blazor.Models
@using GoodHamburger.Blazor.Services
@inject ApiService ApiService

<PageTitle>Inicio - Good Hamburger</PageTitle>

<PageHeader Titulo="Inicio" Descricao="Acesse rapido as principais areas do sistema.">
    <Acoes>
        <a class="btn btn-primary" href="/cadastro">Novo pedido</a>
    </Acoes>
</PageHeader>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<section class="simple-stats">
    <article class="simple-stat">
        <span>Registros</span>
        <strong>@orders.Count</strong>
    </article>

    <article class="simple-stat">
        <span>Faturamento</span>
        <strong>@Moeda(totalRevenue)</strong>
    </article>

    <article class="simple-stat">
        <span>Itens no cardapio</span>
        <strong>@items.Count</strong>
    </article>
</section>

<section class="surface-card section-card">
    <div class="section-card__header">
        <h2>Ultimos registros</h2>
        <a class="text-link" href="/registros">Ver todos</a>
    </div>

    @if (!orders.Any())
    {
        <EmptyState Titulo="Nenhum registro" Descricao="Crie o primeiro pedido para comecar." />
    }
    else
    {
        <div class="simple-list">
            @foreach (var order in orders.OrderByDescending(o => o.CreatedAt).Take(5))
            {
                <a class="simple-list__item" href="/registros/@order.Id">
                    <div>
                        <strong>Pedido #@order.Id</strong>
                        <span>@order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    <strong>@Moeda(order.Total)</strong>
                </a>
            }
        </div>
    }
</section>

@code {
    private List<ItemDto> items = new();
    private List<OrderResponseDto> orders = new();
    private string? errorMessage;

    private decimal totalRevenue => orders.Sum(o => o.Total);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            items = await ApiService.GetItemsAsync();
            orders = await ApiService.GetOrdersAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Nao foi possivel carregar os dados: {ex.Message}";
        }
    }

    private static string Moeda(decimal value) => $"R$ {value:0.00}";
}
