@page "/registros"
@page "/orders"
@using GoodHamburger.Blazor.Models
@using GoodHamburger.Blazor.Services
@inject ApiService ApiService
@inject NavigationManager NavigationManager

<PageTitle>Registros - Good Hamburger</PageTitle>

<PageHeader Titulo="Registros" Descricao="Veja e abra os pedidos cadastrados.">
    <Acoes>
        <a class="btn btn-primary" href="/cadastro">Novo pedido</a>
    </Acoes>
</PageHeader>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<section class="surface-card section-card">
    @if (orders is null)
    {
        <EmptyState Titulo="Carregando" Descricao="Buscando registros." />
    }
    else if (!orders.Any())
    {
        <EmptyState Titulo="Nenhum registro" Descricao="Crie um pedido para aparecer aqui." />
    }
    else
    {
        <div class="table-wrapper table-wrapper--compact">
            <table class="data-table data-table--compact">
                <thead>
                    <tr>
                        <th>Pedido</th>
                        <th>Data</th>
                        <th>Total</th>
                        <th class="actions-column">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in orders.OrderByDescending(o => o.CreatedAt))
                    {
                        <tr>
                            <td>#@order.Id</td>
                            <td>@order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="table-value">@Moeda(order.Total)</td>
                            <td class="actions-cell">
                                <div class="table-actions">
                                    <button class="btn btn-secondary btn-sm" @onclick="() => OpenDetails(order.Id)">Abrir</button>
                                    <button class="btn btn-danger-soft btn-sm" @onclick="() => DeleteOrder(order.Id)">Excluir</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="records-mobile-list">
            @foreach (var order in orders.OrderByDescending(o => o.CreatedAt))
            {
                <article class="record-card record-card--compact">
                    <div class="record-card__header">
                        <strong>Pedido #@order.Id</strong>
                        <strong>@Moeda(order.Total)</strong>
                    </div>
                    <span>@order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                    <div class="record-card__actions">
                        <button class="btn btn-secondary btn-sm" @onclick="() => OpenDetails(order.Id)">Abrir</button>
                        <button class="btn btn-danger-soft btn-sm" @onclick="() => DeleteOrder(order.Id)">Excluir</button>
                    </div>
                </article>
            }
        </div>
    }
</section>

@code {
    private List<OrderResponseDto>? orders;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        errorMessage = null;

        try
        {
            orders = await ApiService.GetOrdersAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar os registros: {ex.Message}";
        }
    }

    private void OpenDetails(int id)
    {
        NavigationManager.NavigateTo($"/registros/{id}");
    }

    private async Task DeleteOrder(int id)
    {
        try
        {
            var result = await ApiService.DeleteOrderAsync(id);

            if (result is null)
            {
                errorMessage = "Nao foi possivel excluir o registro.";
                return;
            }

            await LoadOrders();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao excluir o registro: {ex.Message}";
        }
    }

    private static string Moeda(decimal value) => $"R$ {value:0.00}";
}
