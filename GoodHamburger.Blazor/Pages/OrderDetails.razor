@page "/registros/{Id:int}"
@page "/orders/{Id:int}"
@using GoodHamburger.Blazor.Models
@using GoodHamburger.Blazor.Services
@inject ApiService ApiService
@inject NavigationManager NavigationManager

<PageTitle>Detalhes - Good Hamburger</PageTitle>

<PageHeader Titulo="Detalhes do pedido" Descricao="Veja os itens e o total.">
    <Acoes>
        <button class="btn btn-secondary" @onclick="GoBack">Voltar</button>
    </Acoes>
</PageHeader>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (order is null)
{
    <section class="surface-card">
        <EmptyState Titulo="Carregando" Descricao="Buscando pedido..." />
    </section>
}
else
{
    <section class="simple-stats">
        <article class="simple-stat">
            <span>Pedido</span>
            <strong>#@order.Id</strong>
        </article>
        <article class="simple-stat">
            <span>Subtotal</span>
            <strong>@Currency(order.Subtotal)</strong>
        </article>
        <article class="simple-stat">
            <span>Total</span>
            <strong>@Currency(order.Total)</strong>
        </article>
    </section>

    <section class="surface-card section-card">
        <div class="section-card__header">
            <h2>Itens</h2>
        </div>

        @if (order.Items.Any())
        {
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>Categoria</th>
                            <th>Preço</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in order.Items)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td>@item.Category</td>
                                <td class="table-value">@Currency(item.Price)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <EmptyState Titulo="Sem itens" Descricao="Este pedido não possui itens." />
        }
    </section>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private OrderResponseDto? order;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            order = await ApiService.GetOrderByIdAsync(Id);

            if (order is null)
            {
                errorMessage = "Pedido não encontrado.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar o pedido: {ex.Message}";
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/registros");
    }

    private static string Currency(decimal value) => $"R$ {value:0.00}";
}
