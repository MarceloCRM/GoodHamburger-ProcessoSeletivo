@page "/cadastro"
@page "/create-order"
@using GoodHamburger.Blazor.Models
@using GoodHamburger.Blazor.Services
@inject ApiService ApiService

<PageTitle>Cadastro - Good Hamburger</PageTitle>

<PageHeader Titulo="Novo pedido" Descricao="Escolha os itens e salve.">
    <Acoes>
        <button class="btn btn-secondary" @onclick="ClearSelection">Limpar</button>
    </Acoes>
</PageHeader>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

<section class="builder-layout">
    <div class="builder-layout__content">
        @if (items is null || !items.Any())
        {
            <section class="surface-card">
                <EmptyState Titulo="Carregando cardápio" Descricao="Aguarde um instante." />
            </section>
        }
        else
        {
            @foreach (var category in items.Select(i => i.Category).Distinct().OrderBy(c => c))
            {
                <section class="surface-card section-card">
                    <div class="section-card__header">
                        <h2>@GetCategoryLabel(category)</h2>
                    </div>

                    <div class="menu-grid">
                        @foreach (var item in items.Where(i => i.Category == category))
                        {
                            var isSelected = selectedItemIds.Contains(item.Id);
                            <label class="catalog-card @(isSelected ? "catalog-card--selected" : string.Empty)">
                                <input type="checkbox"
                                       checked="@isSelected"
                                       @onchange="(e => ToggleSelection(item, (bool)(e.Value ?? false)))" />

                                <div class="catalog-card__header">
                                    <strong>@item.Name</strong>
                                    <strong>@Currency(item.Price)</strong>
                                </div>
                            </label>
                        }
                    </div>
                </section>
            }
        }
    </div>

    <aside class="builder-layout__sidebar">
        <div class="surface-card summary-card">
            <div class="section-card__header">
                <h2>Resumo</h2>
            </div>

            @if (!selectedItems.Any())
            {
                <EmptyState Titulo="Sem itens" Descricao="Selecione ao menos um item." />
            }
            else
            {
                <div class="summary-list">
                    @foreach (var item in selectedItems)
                    {
                        <div class="summary-list__row">
                            <span>@item.Name</span>
                            <strong>@Currency(item.Price)</strong>
                        </div>
                    }
                </div>

                <div class="totals-box">
                    <div class="totals-box__row">
                        <span>Subtotal</span>
                        <strong>@Currency(selectedSubtotal)</strong>
                    </div>
                    <div class="totals-box__row">
                        <span>Desconto</span>
                        <strong class="totals-box__discount">- @Currency(selectedDiscount)</strong>
                    </div>
                    <div class="totals-box__row totals-box__row--total">
                        <span>Total</span>
                        <strong>@Currency(selectedTotal)</strong>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(discountDescription))
                {
                    <p class="summary-note">@discountDescription</p>
                }
            }

            <button class="btn btn-primary btn-block" style="margin-top:10px;" @onclick="CreateOrderAsync">Salvar pedido</button>
        </div>
    </aside>
</section>

@code {
    private List<ItemDto> items = new();
    private List<int> selectedItemIds = new();
    private string? successMessage;
    private string? errorMessage;

    private IEnumerable<ItemDto> selectedItems => items.Where(i => selectedItemIds.Contains(i.Id));
    private decimal selectedSubtotal => selectedItems.Sum(i => i.Price);
    private decimal selectedDiscount => decimal.Round(selectedSubtotal * selectedDiscountRate, 2);
    private decimal selectedTotal => selectedSubtotal - selectedDiscount;
    private decimal selectedDiscountRate
    {
        get
        {
            var hasSandwich = selectedItems.Any(i => i.Category == 1);
            var hasFries = selectedItems.Any(i => i.Category == 2);
            var hasDrink = selectedItems.Any(i => i.Category == 3);

            if (hasSandwich && hasFries && hasDrink)
            {
                return 0.20m;
            }

            if (hasSandwich && hasDrink)
            {
                return 0.15m;
            }

            if (hasSandwich && hasFries)
            {
                return 0.10m;
            }

            return 0m;
        }
    }
    private string? discountDescription => selectedDiscountRate switch
    {
        0.20m => "Desconto de 20% aplicado no combo completo.",
        0.15m => "Desconto de 15% aplicado em sanduíche com bebida.",
        0.10m => "Desconto de 10% aplicado em sanduíche com acompanhamento.",
        _ => null
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            items = await ApiService.GetItemsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar o cardápio: {ex.Message}";
        }
    }

    private void ToggleSelection(ItemDto item, bool isChecked)
    {
        selectedItemIds.RemoveAll(id => items.Any(existing => existing.Id == id && existing.Category == item.Category));

        if (isChecked)
        {
            selectedItemIds.Add(item.Id);
        }

        successMessage = null;
        errorMessage = null;
    }

    private async Task CreateOrderAsync()
    {
        if (!selectedItemIds.Any())
        {
            errorMessage = "Selecione pelo menos um item.";
            return;
        }

        successMessage = null;
        errorMessage = null;

        try
        {
            var dto = new CreateOrderDto
            {
                ItemIds = selectedItemIds
            };

            var createdOrder = await ApiService.CreateOrderAsync(dto);

            if (createdOrder is null)
            {
                errorMessage = "Não foi possível salvar o pedido.";
                return;
            }

            successMessage = $"Pedido #{createdOrder.Id} salvo com sucesso.";
            selectedItemIds.Clear();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao salvar o pedido: {ex.Message}";
        }
    }

    private void ClearSelection()
    {
        selectedItemIds.Clear();
        successMessage = null;
        errorMessage = null;
    }

    private static string GetCategoryLabel(int category) => category switch
    {
        1 => "Sanduíches",
        2 => "Acompanhamentos",
        3 => "Bebidas",
        _ => "Outros"
    };

    private static string Currency(decimal value) => $"R$ {value:0.00}";
}
