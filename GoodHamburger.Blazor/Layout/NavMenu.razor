@inject NavigationManager NavigationManager
@implements IDisposable

<ul class="menu-list">
    <li>
        <button class="menu-link @(IsActive("") ? "active" : "")" @onclick='() => NavigateTo("")'>
            <span class="menu-icon">📊</span>
            <span class="menu-label">Dashboard</span>
        </button>
    </li>
    <li>
        <button class="menu-link @(IsActive("create-order") ? "active" : "")" @onclick='() => NavigateTo("create-order")'>
            <span class="menu-icon">🍔</span>
            <span class="menu-label">Novo Pedido</span>
        </button>
    </li>
    <li>
        <button class="menu-link @(IsActive("orders") ? "active" : "")" @onclick='() => NavigateTo("orders")'>
            <span class="menu-icon">📋</span>
            <span class="menu-label">Meus Pedidos</span>
        </button>
    </li>
</ul>

@code {
    private string currentUrl = string.Empty;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    private bool IsActive(string path)
    {
        if (string.IsNullOrEmpty(path))
        {
            return string.IsNullOrEmpty(currentUrl);
        }
        return currentUrl.StartsWith(path, StringComparison.OrdinalIgnoreCase);
    }

    private void NavigateTo(string path)
    {
        NavigationManager.NavigateTo(path);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}