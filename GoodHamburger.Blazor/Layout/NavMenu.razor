<nav class="sidebar-nav" aria-label="Navegação principal">
    <NavLink href="/" Match="NavLinkMatch.All" class="sidebar-nav__item" ActiveClass="sidebar-nav__item--active" @onclick="NotificarNavegacao">
        <span class="sidebar-nav__icon"></span>
        <span class="sidebar-nav__text">Início</span>
    </NavLink>

    <NavLink href="/registros" class="sidebar-nav__item" ActiveClass="sidebar-nav__item--active" @onclick="NotificarNavegacao">
        <span class="sidebar-nav__icon"></span>
        <span class="sidebar-nav__text">Registros</span>
    </NavLink>

    <NavLink href="/cadastro" class="sidebar-nav__item" ActiveClass="sidebar-nav__item--active" @onclick="NotificarNavegacao">
        <span class="sidebar-nav__icon"></span>
        <span class="sidebar-nav__text">Cadastro</span>
    </NavLink>
</nav>

@code {
    [Parameter]
    public EventCallback OnNavigate { get; set; }

    private async Task NotificarNavegacao()
    {
        if (OnNavigate.HasDelegate)
        {
            await OnNavigate.InvokeAsync();
        }
    }
}
